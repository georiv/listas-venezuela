# Gemini does OCR + structuring in one multimodal call (Flash -> Pro fallback)
GEMINI_API_KEY=
# Optional overrides (defaults shown):
# GEMINI_FLASH_MODEL=gemini-2.5-flash
# GEMINI_PRO_MODEL=gemini-2.5-pro

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=

# Comma-separated allowed frontend origins for CORS (set to your Vercel URL in prod)
FRONTEND_ORIGIN=*
